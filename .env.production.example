APP_NAME=Trading Backtesting Platform
APP_ENV=production
DEBUG=false
DATABASE_URL=sqlite:///./trading_platform.db
DATA_DIR=./data
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=2
LOG_LEVEL=INFO
JSON_LOGS=true
CORS_ALLOWED_ORIGINS=https://your-domain.example
TRUSTED_HOSTS=your-domain.example,localhost,127.0.0.1
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_CONTENT_TYPES=text/csv,application/csv,application/vnd.ms-excel,text/plain
SECRET_KEY=replace-with-a-long-random-secret
