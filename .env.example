APP_NAME=Trading Backtesting Platform
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./trading_platform.db
DATA_DIR=./data
HOST=127.0.0.1
PORT=8000
WEB_CONCURRENCY=1
LOG_LEVEL=INFO
JSON_LOGS=false
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:3000,http://localhost:3000
TRUSTED_HOSTS=127.0.0.1,localhost,testserver
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_CONTENT_TYPES=text/csv,application/csv,application/vnd.ms-excel,text/plain
SECRET_KEY=change-me
